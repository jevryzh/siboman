{
  "manifest_version": 3,
  "name": "逐梦 Ozon 采集器",
  "version": "2.2.9.6",
  "description": "配合逐梦 ERP 批量跟卖使用。在 seller.ozon.ru 登录后,自动采集竞品 SKU 的完整商品信息(图片/属性/类目/尺寸)并回传给 ERP。",
  "permissions": [
    "storage",
    "scripting",
    "tabs",
    "cookies",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://*.ozon.ru/*",
    "https://seller.ozon.ru/*",
    "https://api-seller.ozon.ru/*",
    "https://www.ozon.ru/*",
    "https://*.ozonusercontent.com/*",
    "https://cdn1.ozone.ru/*",
    "https://*.ozonru.cn/*",
    "http://test.renwz.cn/*",
    "https://test.renwz.cn/*",
    "http://test.renwz.cn:5178/*",
    "https://test.renwz.cn:5178/*",
    "http://47.104.86.62/*",
    "http://47.104.86.62:5178/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "逐梦 Ozon 采集器"
  },
  "content_scripts": [
    {
      "matches": [
        "http://test.renwz.cn/*",
        "https://test.renwz.cn/*",
        "http://test.renwz.cn:5178/*",
        "https://test.renwz.cn:5178/*",
        "http://47.104.86.62/*",
        "http://47.104.86.62:5178/*"
      ],
      "js": [
        "content-bridge-iso.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": [
        "http://test.renwz.cn/*",
        "https://test.renwz.cn/*",
        "http://test.renwz.cn:5178/*",
        "https://test.renwz.cn:5178/*",
        "http://47.104.86.62/*",
        "http://47.104.86.62:5178/*"
      ],
      "js": [
        "content-bridge-main.js"
      ],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}