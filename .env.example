# Copy this file to .env on each machine and fill in the real secrets.
# Do not commit .env.

# Web server
PORT=5177
HOST=127.0.0.1
APP_PASSWORD=
AUTH_SECRET=

# PostgreSQL server mode. Leave empty for local-only mode.
DATABASE_URL=

# When true, the server only manages login, queue, history, and downloads.
# Real scraping must be done by collector.js on a local collector machine.
DISABLE_SERVER_SCRAPER=true

# Optional initial users for first server boot only.
# Format: username:password:displayName:role,username2:password2:displayName2:role
INITIAL_USERS=

# MiniMax AI
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M3
MINIMAX_THINKING_TYPE=disabled
AI_CONFIDENCE_THRESHOLD=0.78
MINIMAX_INPUT_USD_PER_M=0.30
MINIMAX_OUTPUT_USD_PER_M=1.20

# Scraping behavior
LOW_PRICE_THRESHOLD_RMB=1
DEFAULT_DELAY_MIN_MS=8000
DEFAULT_DELAY_MAX_MS=20000
DETAIL_DELAY_MIN_MS=2500
DETAIL_DELAY_MAX_MS=6500
DETAIL_BROWSE_MODE=balanced
DEFAULT_MAX_CONSECUTIVE_FAILURES=3

# Collector mode. Configure this on each collector computer.
COLLECTOR_SERVER_URL=http://xm.renwz.cn
COLLECTOR_USERNAME=
COLLECTOR_PASSWORD=
COLLECTOR_WORKER_NAME=
COLLECTOR_POLL_SECONDS=5
COLLECTOR_PROGRESS_SECONDS=4

# Ozon Seller API (https://api-seller.ozon.ru/) - 上架到自己的 Ozon 店铺
OZON_SELLER_CLIENT_ID=
OZON_SELLER_API_KEY=
